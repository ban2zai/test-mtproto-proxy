# Сгенерировать секрет (plain hex, 32 символа):
#   python3 -c "import os; print(os.urandom(16).hex())"
#
# В telegram-bot-api использовать как: ee<этот_секрет>
# Пример: если SECRET=abcdef1234567890abcdef1234567890
#   --proxy-secret=eeabcdef1234567890abcdef1234567890
TG_WS_PROXY_SECRET=<вставить-32-char-hex>
