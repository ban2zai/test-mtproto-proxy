TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=replace_with_telegram_api_hash
TELEGRAM_BOT_TOKEN=123456789:replace_with_bot_token

DOCKER_NETWORK=tools_default
DOCKER_IMAGE=ghcr.io/avbor/docker-telegram-bot-api:latest
CLIENT_CONTAINER=tools-n8n-1

TEST_CONTAINER_PREFIX=tg-proxy-check
CHECK_INTERVAL_SECONDS=10
REQUEST_TIMEOUT_SECONDS=10
STARTUP_WAIT_SECONDS=15
DURATION_SECONDS=600

PROXY_1_NAME=proxy-one
PROXY_1_SERVER=example-proxy-1.local
PROXY_1_PORT=443
PROXY_1_SECRET=replace_with_proxy_secret

PROXY_2_NAME=proxy-two
PROXY_2_SERVER=example-proxy-2.local
PROXY_2_PORT=443
PROXY_2_SECRET=replace_with_proxy_secret
